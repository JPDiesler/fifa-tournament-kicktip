# --- Pflicht ---
SESSION_SECRET=bitte-langes-zufalls-secret-eintragen   # für Session-Cookies (z. B. `openssl rand -hex 32`)
ADMIN_PASSWORD=bitte-aendern                            # Passwort des ersten Admins (Benutzername: admin)

# --- Ergebnis-Quelle (API-Football, api-sports.io) ---
# Einzige Datenquelle. Ergebnisse UND Weltmeister werden vollautomatisch geholt:
# getaktet vom Anpfiff bis zum erwarteten Spielende (inkl. Halbzeit, Nachspielzeit,
# Verlängerung, Elfmeterschießen), bis das Endergebnis steht. Live zusätzlich:
# Zwischenstand, Spielminute, Torschützen, Karten, Aufstellung, Statistik und
# (optional) In-Play-Quoten. Season 2026 erfordert einen kostenpflichtigen Plan
# (Free-Plan reicht NICHT). Key: https://dashboard.api-football.com
API_FOOTBALL_KEY=              # API-Sports-Key (Pflicht); auch im Web-Admin setzbar
# API_LEAGUE=1                  # 1 = FIFA World Cup
# API_SEASON=2026
# API_RATE_LIMIT=10             # Calls/Minute (Default 10; an den Plan anpassen)
# API_DAILY_LIMIT=100           # Tageslimit (Default 100; an den Plan anpassen)

# --- "Wo zu sehen" (Sender pro Spiel, Deutschland) ---
# Lineare Sender (ARD/ZDF/RTL/Sky/DAZN) kommen automatisch aus einem deutschen
# TV-Programm (XMLTV), per Teamname+Anstoßzeit den Spielen zugeordnet. Reine
# Streaming-Dienste ohne EPG (MagentaTV/Prime/Netflix) regelt der Rechte-Layer
# in server/lib/broadcasts.js (RIGHTS) — pro Turnier ein paar Zeilen.
# EPG_URL=https://epgshare01.online/epgshare01/epg_ripper_DE1.xml.gz  # XMLTV-Quelle (Default)
# EPG_CRON=30 4 * * *          # täglicher Abgleich (EPG umfasst nur wenige Tage, ändert sich selten)

# --- Admin-Bootstrap (optional) ---
ADMIN_USERNAME=admin
ADMIN_PIN=bitte-aendern   # Fallback-Passwort, falls ADMIN_PASSWORD leer
# Hinweis: Der in ADMIN_USERNAME definierte Account ist immer Superadmin und KEIN Spieler
# (taucht nicht in Rangliste/Tipps auf, kann nicht tippen). ADMIN_KUERZEL wird nicht mehr verwendet.
APP_URL=https://it.wm.albertweil.de   # erscheint als Link im Zugangsdaten-PDF
COOKIE_SECURE=auto        # auto = Cookie nur über HTTPS "secure" (lokal http + Prod https funktionieren beide)
ACCENT_COLOR=             # Akzentfarbe (Weltmeister-Tipp + Turnierbaum-Pfad); leer = Ranglisten-Grün. z. B. "#10b981" oder "oklch(0.7 0.15 250)"

# --- Entra / Microsoft-Login (optional; leer lassen = nur Basic-Login) ---
# Eine SPA-App-Registrierung (public client, PKCE). KEIN Secret nötig:
# Login + ID-Token-Prüfung laufen secretlos; die Entra-Nutzerliste holt der
# Admin delegiert im Browser (Graph-Scope User.ReadBasic.All).
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=

# --- Live-Stände, Quoten & Budget (nur apifootball; optional) ---
# MIN_POLL_MS=1000            # kürzestes Live-Poll-Intervall in ms (Default 1000); braucht großes API-Budget
# INPLAY_ODDS_ENABLED=on      # In-Play-Quoten je Live-Spiel holen (on/off, Default on)
# PREVIEW_CRON=0 * * * *      # Prognose/Quoten-Prefetch (Default stündlich; Staleness-gegatet: Predictions ~4 h, Odds ~3 h)
# DETAIL_MAX_PER_SYNC=        # Obergrenze Detail-Calls pro Sync (Default intern)
# POLL_BUDGET_RESERVE=        # Anteil des Tagesbudgets als Reserve

# --- Web Push (PWA-Benachrichtigungen; optional) ---
# VAPID_PUBLIC_KEY=           # `npx web-push generate-vapid-keys`
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com
# REMINDER_CRON=*/15 * * * *  # Takt der Erinnerungs-Prüfung
# TIP_REMINDER_LEAD_MIN=120   # Tipp-Erinnerung X Min vor Anpfiff
# CHAMP_REMINDER_LEAD_H=24    # Weltmeister-Erinnerung X Std vor dem ersten Spiel

# --- KI-Spieler (LLM-Tipper; optional) ---
# AI_KEY_SECRET=              # Schlüssel zur Verschlüsselung der gespeicherten LLM-API-Keys (sonst aus SESSION_SECRET abgeleitet)
# AI_TIP_CRON=*/10 * * * *    # Takt, in dem fällige KI-Tipps gesetzt werden
# AI_TRIGGER_LEAD_MIN=180     # KI tippt X Min vor Anpfiff
# AI_CHAMP_LEAD_MIN=          # Vorlauf für den KI-Weltmeister-Tipp
# AI_TIMEOUT_MS=              # Timeout je LLM-Call
# AI_FALLBACK=                # Fallback-Verhalten bei LLM-Fehler
# AI_REASONING_VISIBLE_AFTER=kickoff   # KI-Begründung sichtbar ab: kickoff | lock
# OPENAI_REASONING_EFFORT=none         # gpt-5.1 Reasoning (none = aus, gegen Timeouts)

# --- optional ---
SYNC_CRON=0 */6 * * * # Sicherheits-Sync; Ergebnisse werden primär automatisch zu den Spielende-Zeiten geholt
