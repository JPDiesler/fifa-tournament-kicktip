root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
# Deliberately NOT trimming trailing whitespace: the codebase is intentionally
# dense and is not mass-reformatted (Prettier printWidth is 160 and not run
# repo-wide). Let your editor leave existing lines alone.
trim_trailing_whitespace = false

[*.md]
trim_trailing_whitespace = false
